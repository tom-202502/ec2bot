# EC2Bot 环境变量配置模板
# 复制为 .env 后编辑，切勿提交到 Git

# ============================================================
# Telegram Bot Token
# ============================================================
# 从 @BotFather 创建机器人后获取
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ============================================================
# 时区（可选，默认 Asia/Shanghai）
# ============================================================
BOT_TIMEZONE=Asia/Shanghai

# ============================================================
# AWS 认证方式
# ============================================================
# 设为 true 则使用 EC2 实例角色（IAM Role），无需配置 AK/SK
# 设为 false 则使用下方的 Access Key
AWS_USE_INSTANCE_ROLE=false

# ============================================================
# AWS 凭证
# ============================================================
# 变量名需与 config.yaml 中的 access_key_env / secret_key_env 对应
# 也可通过 /secret_add 命令在 Telegram 私聊中录入

# 账户 1
MY_AWS_KEY=AKIAXXXXXXXXXXXXXXXXXX
MY_AWS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MY_AWS_TOKEN=

# 账户 2（示例）
# TEST_AWS_KEY=AKIAXXXXXXXXXXXXXXXXXX
# TEST_AWS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TEST_AWS_TOKEN=
